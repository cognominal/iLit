{
  "extends": "@tsconfig/svelte/tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "types": ["svelte"],
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["../src/lib/*"]
    }
  },
  "include": [
    "../global.d.ts",
    "src/**/*.d.ts",
    "src/**/*.ts",
    "src/**/*.svelte",
    "../src/lib/**/*.ts",
    "../src/lib/**/*.svelte"
  ]
}
